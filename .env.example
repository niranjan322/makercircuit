# ─── MakerCircuit Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values.
# This file is for LOCAL DEVELOPMENT ONLY. Never commit .env to git.

# ─── Supabase ─────────────────────────────────────────────────────────────────
# Project URL → Supabase Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# Service-role secret key (never expose on frontend!)
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Auth ─────────────────────────────────────────────────────────────────────
# JWT signing secret (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret_string

# ─── Email (OTP sending via Nodemailer) ──────────────────────────────────────
# Gmail service — use an App Password (not your real password)
# Enable: https://myaccount.google.com/apppasswords
EMAIL_SERVICE=gmail
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Admin email (user with this email gets access to /api/admin/data)
ADMIN_EMAIL=k.niranjan140506@gmail.com

# ─── Email (optional – if you add OTP/email features later) ───────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@yourdomain.com

# ─── Server / CORS ────────────────────────────────────────────────────────────
# Frontend URL for CORS (your Vercel domain after deploy)
FRONTEND_URL=https://makercircuit.vercel.app

# Server port for local dev
PORT=3000
