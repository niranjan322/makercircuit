# ─── MakerCircuit Environment Variables ──────────────────────────────────────
# Copy this file to .env and fill in the values.
# This file is for LOCAL DEVELOPMENT ONLY. Never commit .env to git.

# MongoDB Atlas connection string
# Get it from: Atlas → Cluster → Connect → Drivers → Node.js
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/makercircuit?retryWrites=true&w=majority

# JWT signing secret (use a long random string)
JWT_SECRET=change_me_to_a_long_random_secret_string

# Resend email API key (https://resend.com → API Keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Sender email address (must be verified in Resend Domain settings)
EMAIL_FROM=noreply@yourdomain.com

# Admin email (hardcoded in server too, but can override via env)
ADMIN_EMAIL=k.niranjan140506@gmail.com

# Frontend URL for CORS (your Vercel domain after deploy)
FRONTEND_URL=https://makercircuit.vercel.app

# Server port for local dev
PORT=3000
